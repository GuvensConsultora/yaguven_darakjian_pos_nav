<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <!-- Inserta la barra de facetas + botón "Categories" + overlay del árbol.
         VERIFICAR EN INSTANCIA: el `expr` del xpath debe apuntar a un contenedor
         real del template point_of_sale.ProductScreen de Odoo 19 (la clase exacta
         de la columna de productos puede diferir). Si no matchea, reapuntar. -->
    <!-- Odoo 19 ProductScreen: no existe 'product-list-container'; el área de
         productos vive en rightpane > position-relative > CategorySelector +
         product-list (t-foreach). Anclamos en CategorySelector que es el primer
         hijo estable del contenedor position-relative, lo que asegura que
         DarakjianCategoryTree quede dentro del ancestro position-relative que
         necesita para su overlay position:absolute/inset:0. -->
    <t t-inherit="point_of_sale.ProductScreen" t-inherit-mode="extension">
        <xpath expr="//CategorySelector" position="before">
            <div class="darakjian-pos-nav">
                <button class="darakjian-tree-toggle btn btn-secondary"
                        t-on-click="() => this.openDarakjianTree()">
                    <i class="fa fa-sitemap me-1"/> Categories
                </button>
                <DarakjianFacetBar/>
            </div>
        </xpath>
        <xpath expr="//CategorySelector" position="after">
            <DarakjianCategoryTree/>
        </xpath>
        <!-- Eliminar el CategorySelector nativo: la navegación de categorías
             se hace exclusivamente a través del árbol vertical custom. -->
        <xpath expr="//CategorySelector" position="replace"/>
    </t>

</templates>
