<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_darakjian_pos_facet_list" model="ir.ui.view">
        <field name="name">darakjian.pos.facet.list</field>
        <field name="model">darakjian.pos.facet</field>
        <field name="arch" type="xml">
            <list string="POS Facets" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="attribute_id"/>
                <field name="label" placeholder="(usa el nombre del atributo)"/>
                <field name="display_type"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_darakjian_pos_facet_form" model="ir.ui.view">
        <field name="name">darakjian.pos.facet.form</field>
        <field name="model">darakjian.pos.facet</field>
        <field name="arch" type="xml">
            <form string="POS Facet">
                <sheet>
                    <group>
                        <field name="attribute_id"/>
                        <field name="label" placeholder="(usa el nombre del atributo)"/>
                        <field name="display_type"/>
                        <field name="sequence"/>
                        <field name="active" widget="boolean_toggle"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_darakjian_pos_facet" model="ir.actions.act_window">
        <field name="name">POS Facets</field>
        <field name="res_model">darakjian.pos.facet</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Configurá las facetas del POS</p>
            <p>Elegí qué atributos de producto se ofrecen como filtros en la pantalla de venta.</p>
        </field>
    </record>

    <!-- VERIFICAR placement: parent menu bajo Point of Sale. menu_point_root es
         estable entre versiones; refinar a Configuración si se prefiere. -->
    <menuitem id="menu_darakjian_pos_facet"
              name="POS Facets"
              parent="point_of_sale.menu_point_root"
              action="action_darakjian_pos_facet"
              sequence="90"/>

</odoo>
